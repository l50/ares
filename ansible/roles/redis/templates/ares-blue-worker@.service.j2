[Unit]
Description=Ares Blue Team Worker (%i)
After=redis.service nats-server.service
Wants=redis.service nats-server.service

[Service]
Type=simple
# `ares-blue worker` gates itself on ARES_WORKER_MODE=blue_task and
# refuses red-team modes, so a mis-wired unit fails fast rather than
# silently kicking off a red worker.
ExecStart={{ redis_ares_blue_worker_binary }} worker
EnvironmentFile=-{{ redis_ares_config_dir }}/env
Environment=ARES_REDIS_URL=redis://{{ redis_bind_address }}:{{ redis_port }}
Environment=NATS_URL=nats://{{ redis_bind_address }}:4222
Environment=ARES_WORKER_ROLE=%i
Environment=ARES_WORKER_MODE=blue_task
Environment=RUST_LOG=info
Environment=OTEL_RESOURCE_ATTRIBUTES={{ redis_ares_blue_otel_resource_attributes }}
Restart=on-failure
RestartSec=5
StandardOutput=append:{{ redis_ares_log_dir }}/blue-%i.log
StandardError=append:{{ redis_ares_log_dir }}/blue-%i.log

# Blue workers spawn their own LLM-driven investigation loop and do not
# fork out to heavy tools like hashcat / netexec, so the resource
# envelope is smaller than the red @-instance template. Sharing the
# system-ares.slice keeps the aggregate fleet cap enforced globally.
Delegate=yes
Slice=system-ares.slice
MemoryHigh={{ redis_ares_worker_memory_high }}
MemoryMax={{ redis_ares_worker_memory_max }}
TasksMax={{ redis_ares_worker_tasks_max }}

[Install]
WantedBy=multi-user.target
